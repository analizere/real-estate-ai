# Database (Neon Postgres)
DATABASE_URL=          # Neon pooled connection string (for app queries)
DATABASE_URL_UNPOOLED= # Neon direct connection string (for migrations only)

# Better Auth
BETTER_AUTH_SECRET=    # Generate: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000  # https://your-domain.com in prod

# Google OAuth
GOOGLE_CLIENT_ID=      # Google Cloud Console -> Credentials -> OAuth 2.0 Client ID
GOOGLE_CLIENT_SECRET=  # Google Cloud Console -> Credentials -> OAuth 2.0 Client Secret

# Resend (Email)
RESEND_API_KEY=        # Resend Dashboard -> API Keys
RESEND_FROM_EMAIL=onboarding@resend.dev  # Dev sandbox; change to hello@yourdomain.com in prod

# Stripe
STRIPE_SECRET_KEY=     # sk_test_... from Stripe Dashboard -> Developers -> API keys
STRIPE_WEBHOOK_SECRET= # whsec_... from: stripe listen --forward-to localhost:3000/api/v1/webhooks/stripe
STRIPE_PRICE_ID_MONTHLY=  # price_... from Stripe Dashboard -> Products -> Real Estate AI Pro -> Monthly
STRIPE_PRICE_ID_ANNUAL=   # price_... from Stripe Dashboard -> Products -> Real Estate AI Pro -> Annual
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY= # pk_test_... from Stripe Dashboard -> Developers -> API keys

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000  # https://your-domain.vercel.app in prod
